generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("STAFF") 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id               String   @id 
  password         String   @default("student123") // NEW: Student Login Password
  firstName        String
  lastName         String
  dob              DateTime
  gender           String
  imageUrl         String?
  badges           String?
  classId          String?
  class            Class?   @relation(fields: [classId], references: [id])
  parentId         String?
  parent           Parent?  @relation(fields: [parentId], references: [id])
  previousSchool   String?
  status           String   @default("ACTIVE") 
  enrollmentDate   DateTime @default(now())
  grades           Grade[]
  invoices         Invoice[]
  skillRatings     SkillRating[]
  cbtResults       CBTResult[] 
  internalResults  InternalResult[] 

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Parent {
  id        String    @id @default(cuid())
  password  String    @default("parent123") // NEW: Parent Login Password
  fullName  String
  email     String?
  phone     String
  students  Student[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Staff {
  id          String   @id 
  firstName   String
  lastName    String
  email       String?  @unique
  phone       String
  role        String   @default("TEACHER") 
  status      String   @default("ACTIVE")  
  classes     Class[]  
  timetableEntries TimetableEntry[] 
  lessonPlans LessonPlan[] 

  hireDate    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Class {
  id        String    @id @default(cuid())
  name      String    @unique 
  level     String    
  teacherId String?
  teacher   Staff?    @relation(fields: [teacherId], references: [id])
  students  Student[]
  timetableEntries TimetableEntry[]
  internalExams    InternalExam[]
  questionBank     QuestionBank[] 
  lessonPlans      LessonPlan[] 
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Subject {
  id        String    @id @default(cuid())
  name      String    @unique 
  grades    Grade[]
  timetableEntries TimetableEntry[]
  internalExams    InternalExam[]
  questionBank     QuestionBank[] 
  lessonPlans      LessonPlan[] 
  ministrySchemes  MinistryScheme[] 
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model TimetableEntry {
  id        String   @id @default(cuid())
  dayOfWeek String   
  startTime String   
  endTime   String   
  room      String?  
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherId String?
  teacher   Staff?   @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Grade {
  id        String   @id @default(cuid())
  ca1       Float?   @default(0)
  ca2       Float?   @default(0)
  exam      Float?   @default(0)
  total     Float?   @default(0)
  letter    String?  
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  term      String   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([studentId, subjectId, term])
}

model SkillRating {
  id        String   @id @default(cuid())
  category  String   
  name      String   
  rating    Int      
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term      String   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([studentId, name, term])
}

model Invoice {
  id          String   @id 
  description String   
  amount      Float
  status      String   @default("PENDING") 
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  issuedDate  DateTime @default(now())
  dueDate     DateTime
  paidDate    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ------------------------------------------------------
// EXTERNAL ENTRANCE EXAMS (CBT)
// ------------------------------------------------------
model EntranceExam {
  id              String   @id @default(cuid())
  title           String   
  description     String?
  scheduledDate   DateTime
  startTime       String   
  durationMinutes Int      @default(60)
  status          String   @default("UPCOMING") 
  questions       ExamQuestion[]
  results         CBTResult[] 
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ExamQuestion {
  id            String   @id @default(cuid())
  section       String   @default("English Studies") 
  text          String   
  imageUrl      String?  
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String   
  marks         Float    @default(1.0)
  orderIndex    Int      
  examId        String
  exam          EntranceExam @relation(fields: [examId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CBTResult {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examId      String
  exam        EntranceExam @relation(fields: [examId], references: [id], onDelete: Cascade)
  score       Float
  totalMarks  Float
  submittedAt DateTime @default(now())
  @@unique([studentId, examId])
}

// ------------------------------------------------------
// INTERNAL EXAMS (CBT)
// ------------------------------------------------------
model InternalExam {
  id              String   @id @default(cuid())
  title           String   
  classId         String
  class           Class    @relation(fields: [classId], references: [id])
  subjectId       String
  subject         Subject  @relation(fields: [subjectId], references: [id])
  term            String   @default("Term 1 - 2024")
  durationMinutes Int      @default(60)
  isActive        Boolean  @default(false)
  shuffleQuestions Boolean @default(false) 
  questions       InternalQuestion[]
  results         InternalResult[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model InternalQuestion {
  id            String   @id @default(cuid())
  text          String   
  imageUrl      String?  
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String   
  marks         Float    @default(1.0)
  orderIndex    Int      
  examId        String
  exam          InternalExam @relation(fields: [examId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model InternalResult {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examId      String
  exam        InternalExam @relation(fields: [examId], references: [id], onDelete: Cascade)
  score       Float
  totalMarks  Float
  submittedAt DateTime @default(now())
  @@unique([studentId, examId])
}

// ------------------------------------------------------
// QUESTION BANK 
// ------------------------------------------------------
model QuestionBank {
  id            String   @id @default(cuid())
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  classId       String?
  class         Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  text          String   
  imageUrl      String?  
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String   
  marks         Float    @default(1.0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ------------------------------------------------------
// MINISTRY SCHEME OF WORK 
// ------------------------------------------------------
model MinistryScheme {
  id          String   @id @default(cuid())
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  level       String   
  week        Int
  topic       String
  objectives  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ------------------------------------------------------
// LESSON PLANS 
// ------------------------------------------------------
model LessonPlan {
  id            String   @id @default(cuid())
  title         String
  week          Int      @default(1)
  
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  classId       String
  class         Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacherId     String?
  teacher       Staff?   @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  
  schemeOfWork  String?  
  lessonNote    String?
  evaluation    String?
  assignment    String?

  status        String   @default("DRAFT") 

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ------------------------------------------------------
// CONFIGURATION
// ------------------------------------------------------
model AcademicTerm {
  id        String   @id @default(cuid())
  name      String   
  session   String   
  isCurrent Boolean  @default(false)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  type        String   @default("GENERAL") 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
